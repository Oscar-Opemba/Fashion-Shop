# Copy to .env and fill in. Never commit .env.

# --- Django ---
SECRET_KEY=generate-with-python-c-import-secrets-print-secrets-token-urlsafe-50
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Add your ngrok host here when testing M-Pesa, e.g. https://abc123.ngrok-free.app
CSRF_TRUSTED_ORIGINS=

# --- M-Pesa Daraja (Lipa na M-Pesa Online / STK Push) ---
# Get these from https://developer.safaricom.co.ke:
#   1. Register and log in.
#   2. My Apps -> Add a new App, tick "Lipa Na M-Pesa Sandbox".
#      This gives you the Consumer Key and Consumer Secret.
#   3. APIs -> Lipa Na M-Pesa Online -> Simulate shows the sandbox
#      Shortcode (174379) and the Passkey.
#   4. That same page lists the sandbox test phone numbers and PIN.
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=

# Safaricom POSTs the payment result here, so it must be a public https url.
# In development: run `ngrok http 8000` and paste the forwarding url below.
MPESA_CALLBACK_BASE_URL=

# Random string that becomes part of the callback path. The callback cannot be
# authenticated, so an unguessable url is what keeps it from being spammed.
MPESA_CALLBACK_TOKEN=generate-a-random-string

MPESA_TRANSACTION_DESC=Online purchase
