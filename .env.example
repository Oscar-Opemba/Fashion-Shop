# Copy to .env and fill in. Never commit .env.

# --- Django ---
SECRET_KEY=generate-with-python-c-import-secrets-print-secrets-token-urlsafe-50
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Only needed when the site is served over https on another host,
# e.g. https://shop.example.com
CSRF_TRUSTED_ORIGINS=

# --- Social login (optional) ---
# Leave a pair blank and that provider's button simply does not appear.
#
# Google — https://console.cloud.google.com/apis/credentials
#   Create Credentials -> OAuth client ID -> Web application.
#   Authorised redirect URI:
#     http://localhost:8000/accounts/google/login/callback/
#   (and the https equivalent for every domain you deploy to).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook — https://developers.facebook.com/apps
#   Add the "Facebook Login" product. The App ID is the client id, the
#   App Secret the client secret. Valid OAuth Redirect URI:
#     https://<your-domain>/accounts/facebook/login/callback/
#   Facebook requires https, so a tunnel is needed when testing locally.
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
